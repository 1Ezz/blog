---
interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+SC:wght@400;600;700&family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  </head>
  <body>
    <div class="noise-overlay"></div>
    <div class="grain-overlay"></div>

    <header>
      <div class="header-inner">
        <a href="/" class="logo">
          <span class="logo-mark">ez</span>
          <span class="logo-dot"></span>
        </a>
        <nav>
          <a href="/">首页</a>
          <a href="/blog">文章</a>
          <a href="/about">关于</a>
        </nav>
        <div class="header-line"></div>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer>
      <div class="footer-inner">
        <div class="footer-decoration"></div>
        <p>&copy; 2026 ez. 用文字记录成长。</p>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  :root {
    --color-bg: #121318;
    --color-bg-elevated: #1a1b21;
    --color-text: #f5f2eb;
    --color-text-muted: #9a9590;
    --color-accent: #c75d3a;
    --color-accent-hover: #e07050;
    --color-border: #2a2b32;
    --font-serif: 'Noto Serif SC', 'Source Serif Pro', Georgia, serif;
    --font-display: 'Playfair Display', 'Times New Roman', serif;
    --font-mono: 'JetBrains Mono', 'Fira Code', monospace;
    --max-width: 720px;
    --header-height: 72px;
  }

  * {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html {
    scroll-behavior: smooth;
    background: var(--color-bg);
    color: var(--color-text);
    font-family: var(--font-serif);
    line-height: 1.8;
    font-size: 18px;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  body {
    min-height: 100vh;
    position: relative;
    overflow-x: hidden;
  }

  /* Grain texture overlay */
  .noise-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 1000;
    opacity: 0.03;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
  }

  .grain-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 999;
    background:
      radial-gradient(ellipse at 20% 0%, rgba(199, 93, 58, 0.08) 0%, transparent 50%),
      radial-gradient(ellipse at 80% 100%, rgba(199, 93, 58, 0.05) 0%, transparent 50%);
  }

  header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    height: var(--header-height);
    background: linear-gradient(to bottom, var(--color-bg) 60%, transparent);
  }

  .header-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 2rem;
    height: 100%;
    display: flex;
    align-items: center;
    gap: 3rem;
    position: relative;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    text-decoration: none;
    color: var(--color-text);
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    animation: fadeInLeft 0.6s ease-out;
  }

  .logo-mark {
    position: relative;
  }

  .logo-dot {
    width: 6px;
    height: 6px;
    background: var(--color-accent);
    border-radius: 50%;
    margin-left: 2px;
    animation: pulse 2s ease-in-out infinite;
  }

  nav {
    display: flex;
    gap: 2rem;
    animation: fadeIn 0.6s ease-out 0.1s both;
  }

  nav a {
    color: var(--color-text-muted);
    text-decoration: none;
    font-size: 0.9rem;
    letter-spacing: 0.02em;
    transition: color 0.3s ease;
    position: relative;
  }

  nav a::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 0;
    width: 0;
    height: 1px;
    background: var(--color-accent);
    transition: width 0.3s ease;
  }

  nav a:hover {
    color: var(--color-text);
  }

  nav a:hover::after {
    width: 100%;
  }

  .header-line {
    position: absolute;
    bottom: 0;
    left: 2rem;
    right: 2rem;
    height: 1px;
    background: linear-gradient(to right, var(--color-border), transparent 50%);
  }

  main {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: calc(var(--header-height) + 4rem) 2rem 4rem;
    min-height: 100vh;
  }

  footer {
    border-top: 1px solid var(--color-border);
    padding: 3rem 2rem;
    position: relative;
  }

  .footer-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    text-align: center;
    position: relative;
  }

  .footer-decoration {
    width: 40px;
    height: 2px;
    background: var(--color-accent);
    margin: 0 auto 1.5rem;
  }

  footer p {
    color: var(--color-text-muted);
    font-size: 0.85rem;
  }

  /* Typography */
  h1, h2, h3, h4, h5, h6 {
    font-family: var(--font-display);
    font-weight: 600;
    line-height: 1.3;
    color: var(--color-text);
    letter-spacing: -0.01em;
  }

  h1 {
    font-size: clamp(2.5rem, 6vw, 3.5rem);
    font-weight: 700;
    margin-bottom: 1.5rem;
    animation: fadeInUp 0.8s ease-out;
  }

  h2 {
    font-size: clamp(1.5rem, 4vw, 2rem);
    margin-top: 3rem;
    margin-bottom: 1rem;
    position: relative;
    display: inline-block;
  }

  h2::before {
    content: '';
    position: absolute;
    left: -1rem;
    top: 50%;
    transform: translateY(-50%);
    width: 3px;
    height: 1.2em;
    background: var(--color-accent);
  }

  h3 {
    font-size: 1.3rem;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }

  p {
    margin-bottom: 1.5rem;
    color: var(--color-text);
  }

  a {
    color: var(--color-accent);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  a:hover {
    color: var(--color-accent-hover);
  }

  /* Code */
  code {
    font-family: var(--font-mono);
    background: var(--color-bg-elevated);
    padding: 0.2em 0.5em;
    border-radius: 4px;
    font-size: 0.85em;
    border: 1px solid var(--color-border);
  }

  pre {
    background: var(--color-bg-elevated);
    padding: 1.5rem;
    border-radius: 8px;
    overflow-x: auto;
    border: 1px solid var(--color-border);
    margin: 1.5rem 0;
  }

  pre code {
    background: none;
    padding: 0;
    border: none;
    font-size: 0.9em;
    line-height: 1.6;
  }

  img {
    max-width: 100%;
    height: auto;
    border-radius: 6px;
  }

  hr {
    border: none;
    height: 1px;
    background: var(--color-border);
    margin: 3rem 0;
  }

  /* Animations */
  @keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes fadeInLeft {
    from {
      opacity: 0;
      transform: translateX(-10px);
    }
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.6; transform: scale(0.8); }
  }

  /* Scrollbar */
  ::-webkit-scrollbar {
    width: 8px;
    height: 8px;
  }

  ::-webkit-scrollbar-track {
    background: var(--color-bg);
  }

  ::-webkit-scrollbar-thumb {
    background: var(--color-border);
    border-radius: 4px;
  }

  ::-webkit-scrollbar-thumb:hover {
    background: var(--color-text-muted);
  }

  /* Selection */
  ::selection {
    background: var(--color-accent);
    color: var(--color-bg);
  }

  /* Focus */
  :focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  /* Responsive */
  @media (max-width: 640px) {
    html {
      font-size: 16px;
    }

    .header-inner {
      gap: 1.5rem;
    }

    nav {
      gap: 1.25rem;
    }

    h2::before {
      left: -0.75rem;
    }
  }
</style>
