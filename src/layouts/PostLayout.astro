---
import BaseLayout from './BaseLayout.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { title, description, pubDate, updatedDate, heroImage, tags } = post.data;

const formattedDate = pubDate.toLocaleDateString('zh-CN', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const formattedUpdatedDate = updatedDate?.toLocaleDateString('zh-CN', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title={title} description={description}>
  <article>
    <header>
      {heroImage && <img src={heroImage} alt={title} />}
      <h1>{title}</h1>
      <div class="meta">
        <time datetime={pubDate.toISOString()}>{formattedDate}</time>
        {tags && <span class="tags">{tags.join(', ')}</span>}
      </div>
      {updatedDate && <p class="updated">更新于: {formattedUpdatedDate}</p>}
    </header>
    <div class="content">
      <slot />
    </div>
    <hr />
    <div id="giscus-container"></div>
  </article>
</BaseLayout>

<script>
  // Giscus 评论系统
  const script = document.createElement('script');
  script.src = 'https://giscus.app/client.js';
  script.setAttribute('data-repo', '1Ezz/blog');
  script.setAttribute('data-repo-id', 'R_kgDOSIGw_Q');
  script.setAttribute('data-category', 'Announcements');
  script.setAttribute('data-category-id', 'DIC_kwDOSIGw_c4C7T6q');
  script.setAttribute('data-mapping', 'pathname');
  script.setAttribute('data-strict', '0');
  script.setAttribute('data-reactions-enabled', '1');
  script.setAttribute('data-emit-metadata', '0');
  script.setAttribute('data-input-position', 'top');
  script.setAttribute('data-theme', 'preferred_color_scheme');
  script.setAttribute('data-lang', 'zh-CN');
  script.crossorigin = 'anonymous';
  script.async = true;
  document.getElementById('giscus-container')?.appendChild(script);
</script>

<style>
  article {
    max-width: 100%;
  }
  header {
    margin-bottom: 2rem;
  }
  header img {
    width: 100%;
    height: auto;
    border-radius: 8px;
    margin-bottom: 1.5rem;
  }
  h1 {
    margin-top: 0;
    margin-bottom: 0.5rem;
  }
  .meta {
    color: #666;
    font-size: 0.875rem;
    display: flex;
    gap: 1rem;
    align-items: center;
  }
  .tags {
    background: #f0f0f0;
    padding: 0.125rem 0.5rem;
    border-radius: 4px;
  }
  .updated {
    font-size: 0.8rem;
    color: #999;
  }
  .content {
    line-height: 1.8;
  }
</style>