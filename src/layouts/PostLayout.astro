---
import BaseLayout from './BaseLayout.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { title, description, pubDate, updatedDate, heroImage, tags } = post.data;

const formattedDate = pubDate.toLocaleDateString('zh-CN', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const formattedUpdatedDate = updatedDate?.toLocaleDateString('zh-CN', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title={title} description={description}>
  <article class="post">
    <header class="post-header">
      <div class="header-eyebrow">
        <a href="/blog" class="back-link">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M19 12H5M12 19l-7-7 7-7"/>
          </svg>
          返回
        </a>
        <span class="separator">/</span>
        <span class="reading-time">阅读</span>
      </div>
      <h1 class="post-title">{title}</h1>
      <div class="post-meta">
        <time datetime={pubDate.toISOString()} class="pub-date">{formattedDate}</time>
        {tags && (
          <div class="post-tags">
            {tags.map(tag => (
              <span class="tag">{tag}</span>
            ))}
          </div>
        )}
      </div>
      {updatedDate && (
        <p class="updated">更新于: {formattedUpdatedDate}</p>
      )}
    </header>

    {heroImage && (
      <div class="hero-image-wrapper">
        <img src={heroImage} alt={title} class="hero-image" loading="eager" />
      </div>
    )}

    <div class="post-content">
      <slot />
    </div>

    <footer class="post-footer">
      <div class="footer-decoration">
        <span class="decoration-line"></span>
        <span class="decoration-mark">·</span>
        <span class="decoration-line"></span>
      </div>
      <div class="giscus-wrapper">
        <div id="giscus-container"></div>
      </div>
    </footer>
  </article>
</BaseLayout>

<script>
  // Giscus 评论系统
  const script = document.createElement('script');
  script.src = 'https://giscus.app/client.js';
  script.setAttribute('data-repo', '1Ezz/blog');
  script.setAttribute('data-repo-id', 'R_kgDOSIGw_Q');
  script.setAttribute('data-category', 'Announcements');
  script.setAttribute('data-category-id', 'DIC_kwDOSIGw_c4C7T6q');
  script.setAttribute('data-mapping', 'pathname');
  script.setAttribute('data-strict', '0');
  script.setAttribute('data-reactions-enabled', '1');
  script.setAttribute('data-emit-metadata', '0');
  script.setAttribute('data-input-position', 'top');
  script.setAttribute('data-theme', 'dark');
  script.setAttribute('data-lang', 'zh-CN');
  script.crossorigin = 'anonymous';
  script.async = true;
  document.getElementById('giscus-container')?.appendChild(script);
</script>

<style>
  .post {
    max-width: 100%;
    animation: fadeIn 0.6s ease-out;
  }

  .post-header {
    padding: 2rem 0 3rem;
    margin-bottom: 2rem;
    border-bottom: 1px solid var(--color-border);
  }

  .header-eyebrow {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
    font-size: 0.85rem;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    color: var(--color-text-muted);
    transition: color 0.2s ease;
  }

  .back-link:hover {
    color: var(--color-accent);
  }

  .back-link svg {
    transition: transform 0.2s ease;
  }

  .back-link:hover svg {
    transform: translateX(-3px);
  }

  .separator {
    color: var(--color-border);
  }

  .reading-time {
    color: var(--color-text-muted);
  }

  .post-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 700;
    line-height: 1.2;
    margin: 0 0 1.5rem;
    animation: fadeInUp 0.7s ease-out 0.1s both;
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    flex-wrap: wrap;
    animation: fadeInUp 0.7s ease-out 0.2s both;
  }

  .pub-date {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }

  .post-tags {
    display: flex;
    gap: 0.5rem;
  }

  .tag {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    padding: 0.25rem 0.6rem;
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-border);
    border-radius: 3px;
    color: var(--color-text-muted);
  }

  .updated {
    margin-top: 0.75rem;
    font-size: 0.8rem;
    color: var(--color-text-muted);
    opacity: 0.7;
  }

  .hero-image-wrapper {
    margin-bottom: 3rem;
    border-radius: 8px;
    overflow: hidden;
    animation: fadeInUp 0.7s ease-out 0.3s both;
  }

  .hero-image {
    width: 100%;
    height: auto;
    display: block;
    border-radius: 8px;
  }

  .post-content {
    animation: fadeInUp 0.7s ease-out 0.4s both;
  }

  /* Prose styling for markdown content */
  .post-content :global(h1),
  .post-content :global(h2),
  .post-content :global(h3),
  .post-content :global(h4) {
    font-family: var(--font-display);
    margin-top: 2.5rem;
    margin-bottom: 1rem;
  }

  .post-content :global(h1) { font-size: 2rem; }
  .post-content :global(h2) {
    font-size: 1.6rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--color-border);
  }
  .post-content :global(h3) { font-size: 1.3rem; }

  .post-content :global(p) {
    margin-bottom: 1.5rem;
    line-height: 1.9;
  }

  .post-content :global(a) {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: color 0.2s ease;
  }

  .post-content :global(a:hover) {
    color: var(--color-accent-hover);
  }

  .post-content :global(ul),
  .post-content :global(ol) {
    margin: 1.5rem 0;
    padding-left: 1.5rem;
  }

  .post-content :global(li) {
    margin-bottom: 0.5rem;
    line-height: 1.7;
  }

  .post-content :global(blockquote) {
    margin: 2rem 0;
    padding: 1.5rem 2rem;
    border-left: 3px solid var(--color-accent);
    background: var(--color-bg-elevated);
    border-radius: 0 8px 8px 0;
    font-style: italic;
  }

  .post-content :global(blockquote p) {
    margin: 0;
  }

  .post-content :global(img) {
    max-width: 100%;
    height: auto;
    border-radius: 6px;
    margin: 2rem 0;
  }

  .post-content :global(hr) {
    margin: 3rem 0;
    border: none;
    height: 1px;
    background: var(--color-border);
  }

  /* Footer */
  .post-footer {
    margin-top: 4rem;
    padding-top: 2rem;
  }

  .footer-decoration {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    margin-bottom: 3rem;
  }

  .decoration-line {
    width: 60px;
    height: 1px;
    background: var(--color-border);
  }

  .decoration-mark {
    color: var(--color-accent);
    font-size: 1.5rem;
  }

  .giscus-wrapper {
    min-height: 200px;
  }

  @media (max-width: 640px) {
    .post-header {
      padding: 1.5rem 0 2rem;
    }

    .post-meta {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.75rem;
    }

    .footer-decoration {
      margin-bottom: 2rem;
    }

    .decoration-line {
      width: 40px;
    }
  }
</style>
