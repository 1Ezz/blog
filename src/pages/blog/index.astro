---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<BaseLayout title="博客" description="博客文章列表">
  <section class="page-header">
    <div class="page-header-eyebrow">
      <span class="line"></span>
      <span>Writing</span>
    </div>
    <h1>文章</h1>
    <p class="page-desc">一些文字，一些想法。</p>
  </section>

  <section class="posts-section">
    <div class="posts-list">
      {posts.map((post, index) => (
        <a href={`/blog/${post.id}/`} class="post-item" style={`--delay: ${index * 0.08}s`}>
          <div class="post-item-inner">
            <div class="post-date">
              <time datetime={post.data.pubDate.toISOString()}>
                {post.data.pubDate.toLocaleDateString('zh-CN', { year: 'numeric' })}
              </time>
              <span class="post-month">
                {post.data.pubDate.toLocaleDateString('zh-CN', { month: 'short' })}
              </span>
            </div>
            <div class="post-content">
              <h2>{post.data.title}</h2>
              <p>{post.data.description}</p>
              {post.data.tags && (
                <div class="post-tags">
                  {post.data.tags.map(tag => (
                    <span class="tag">{tag}</span>
                  ))}
                </div>
              )}
            </div>
            <div class="post-arrow">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M5 12h14M12 5l7 7-7 7"/>
              </svg>
            </div>
          </div>
        </a>
      ))}
    </div>

    {posts.length === 0 && (
      <div class="empty-state">
        <p>暂无文章，敬请期待。</p>
      </div>
    )}
  </section>
</BaseLayout>

<style>
  .page-header {
    padding: 3rem 0 4rem;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 3rem;
  }

  .page-header-eyebrow {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-text-muted);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin-bottom: 1rem;
    animation: fadeIn 0.5s ease-out;
  }

  .page-header-eyebrow .line {
    width: 24px;
    height: 1px;
    background: var(--color-accent);
  }

  h1 {
    font-size: clamp(2.5rem, 6vw, 3.5rem);
    font-weight: 700;
    margin-bottom: 1rem;
    animation: fadeInUp 0.6s ease-out 0.1s both;
  }

  .page-desc {
    color: var(--color-text-muted);
    font-size: 1.1rem;
    margin: 0;
    animation: fadeInUp 0.6s ease-out 0.15s both;
  }

  .posts-section {
    animation: fadeIn 0.6s ease-out 0.2s both;
  }

  .posts-list {
    display: flex;
    flex-direction: column;
  }

  .post-item {
    display: block;
    border-bottom: 1px solid var(--color-border);
    transition: background 0.3s ease;
    animation: fadeInUp 0.5s ease-out calc(var(--delay) + 0.2s) both;
  }

  .post-item:first-child {
    border-top: 1px solid var(--color-border);
  }

  .post-item:hover {
    background: var(--color-bg-elevated);
  }

  .post-item-inner {
    display: grid;
    grid-template-columns: 80px 1fr auto;
    gap: 2rem;
    padding: 2rem 0;
    align-items: center;
  }

  .post-date {
    text-align: center;
    opacity: 0.7;
    transition: opacity 0.3s ease;
  }

  .post-item:hover .post-date {
    opacity: 1;
  }

  .post-date time {
    display: block;
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 600;
    line-height: 1;
    margin-bottom: 0.25rem;
  }

  .post-month {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    font-family: var(--font-mono);
  }

  .post-content h2 {
    font-family: var(--font-display);
    font-size: 1.4rem;
    font-weight: 600;
    margin: 0 0 0.5rem;
    transition: color 0.2s ease;
  }

  .post-item:hover .post-content h2 {
    color: var(--color-accent);
  }

  .post-content p {
    color: var(--color-text-muted);
    font-size: 0.95rem;
    margin: 0 0 0.75rem;
    line-height: 1.6;
  }

  .post-tags {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .tag {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    padding: 0.2rem 0.5rem;
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-border);
    border-radius: 3px;
    color: var(--color-text-muted);
  }

  .post-arrow {
    color: var(--color-accent);
    opacity: 0;
    transform: translateX(-8px);
    transition: opacity 0.3s ease, transform 0.3s ease;
  }

  .post-item:hover .post-arrow {
    opacity: 1;
    transform: translateX(0);
  }

  .empty-state {
    text-align: center;
    padding: 4rem 2rem;
    color: var(--color-text-muted);
  }

  @media (max-width: 640px) {
    .post-item-inner {
      grid-template-columns: 1fr;
      gap: 0.75rem;
      padding: 1.5rem 0;
    }

    .post-date {
      text-align: left;
      display: flex;
      align-items: baseline;
      gap: 0.5rem;
    }

    .post-date time {
      font-size: 1rem;
      margin-bottom: 0;
    }

    .post-arrow {
      display: none;
    }
  }
</style>
